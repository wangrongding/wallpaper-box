{
  "name": "wallpaper-box",
  "private": true,
  "type": "commonjs",
  "version": "1.0.1",
  "main": "./dist-electron/main.js",
  "description": "让桌面真正活起来：静态壁纸、视频壁纸、网页壁纸和 RunCat 托盘动画，一个客户端全搞定。",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "prepare": "node ./scripts/prepare-video-downloader-binaries.mjs && husky",
    "dev": "node ./dev.mjs",
    "dev:web": "vite",
    "dev:electron": "node ./dev-electron.mjs",
    "dev:sort": "vite --mode sort",
    "prepare:video-downloader": "node ./scripts/prepare-video-downloader-binaries.mjs --force",
    "preview": "vite preview",
    "build": "pnpm build:mac:universal",
    "build:web": "tsc && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:dmg": "rm -rf ./out && pnpm build:web && pnpm build:electron && electron-builder --mac dmg --universal",
    "build:zip": "rm -rf ./out && pnpm build:web && pnpm build:electron && electron-builder --mac zip --universal",
    "build:mac": "rm -rf ./out && pnpm build:web && pnpm build:electron && electron-builder --mac",
    "build:mac:universal": "rm -rf ./out && pnpm build:web && pnpm build:electron && electron-builder --mac --universal",
    "build:mac:x64": "rm -rf ./out && pnpm build:web && pnpm build:electron && electron-builder --mac --x64",
    "build:mac:arm64": "rm -rf ./out && pnpm build:web && pnpm build:electron && electron-builder --mac --arm64",
    "electron": "electron .",
    "electron:start": "pnpm build:electron && cross-env ELECTRON_RUN_AS_NODE= IS_DEV=false electron .",
    "electron:dev": "pnpm build:electron && cross-env ELECTRON_RUN_AS_NODE= IS_DEV=true electron .",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ffmpeg/core": "0.11.0",
    "@ffmpeg/ffmpeg": "0.11.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "ahooks": "3.7.4",
    "axios": "1.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "8.1.0",
    "fs-extra": "^11.1.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.563.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^8.0.5",
    "react-router-dom": "^6.6.1",
    "redux": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "wallpaper": "^7.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^4.2.0",
    "@types/fs-extra": "^9.0.13",
    "@types/lodash": "^4.14.191",
    "@types/node": "^18.11.17",
    "@types/react": "^18.0.26",
    "@types/react-dom": "^18.0.9",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.13",
    "chokidar": "^3.5.3",
    "cross-env": "^7.0.3",
    "electron": "41.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^10.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.20",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.5.3",
    "rollup": "^3.8.1",
    "rollup-plugin-node-polyfills": "^0.2.1",
    "rollup-plugin-typescript2": "^0.34.1",
    "sass": "^1.98.0",
    "tailwindcss": "^3.2.4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^4.9.3",
    "unplugin-auto-import": "^0.12.1",
    "vite": "^8.0.3",
    "vite-plugin-esmodule": "^1.4.4",
    "vite-plugin-optimizer": "^1.4.2",
    "vite-plugin-svg-icons": "^2.0.1"
  },
  "build": {
    "appId": "com.wallpaper-box.app",
    "productName": "wallpaper-box",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist-electron/**/*",
      "dist-web/**/*"
    ],
    "asarUnpack": [
      "node_modules/wallpaper/**/*"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "icon": "./public/logo.icns",
      "minimumSystemVersion": "10.13",
      "x64ArchFiles": "{Contents/Resources/bin/**/*,Contents/Resources/bin/**/.dylibs/**/*}",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "wallpaper-box"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "@parcel/watcher"
    ]
  }
}
